# Production Environment Configuration
# This file is committed to git (no sensitive data here)

NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_API_URL=https://agentic-weather-app.vercel.app
NODE_ENV=production

# LLM Configuration - Use environment variable injected at runtime
LLM_PROVIDER=openrouter
OLLAMA_MODEL=llama3.2

# Image Provider - Will use PEXELS_API_KEY from GitHub Secrets
# PEXELS_API_KEY is injected via GitHub Actions secrets

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Feature Flags
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_DEBUG_MODE=false
